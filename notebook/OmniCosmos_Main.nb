Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"LaunchOmniCosmos", "[", "]"}]], "Input",
 CellChangeTimes->{{3.985401249397965*^9, 3.9854012493980103`*^9}, {
  3.985415132591316*^9, 3.985415135753274*^9}},
 CellLabel->"In[24]:=",ExpressionUUID->"39f7c8cb-aa7b-48ff-a17d-6bc374bc71ae"],

Cell[BoxData[
 DynamicModuleBox[{OmniCosmos`Private`exercise$$ = <|
  "level" -> 1, "type" -> "text", "question" -> 
   "Qual \[EGrave] il pianeta pi\[UGrave] grande?", "answer" -> "giove", 
   "hint" -> "\[CapitalEGrave] il quinto pianeta"|>, 
  OmniCosmos`Private`userAnswer$$ = "terra", OmniCosmos`Private`feedback$$ = 
  "\:274c Sbagliato \[RightArrow] \[CapitalEGrave] il quinto pianeta", 
  OmniCosmos`Private`level$$ = 1, OmniCosmos`Private`score$$ = 0}, 
  PanelBox[
   TagBox[GridBox[{
      {
       StyleBox["\<\"\|01f30c Modulo Accademia\"\>",
        StripOnInput->False,
        FontSize->20,
        FontWeight->Bold]},
      {
       TemplateBox[{"\"Score: \"", 
         DynamicBox[
          ToBoxes[OmniCosmos`Private`score$$, StandardForm]]},
        "RowDefault"]},
      {
       InterpretationBox[
        StyleBox[GridBox[{
           {
            
            SetterBox[Dynamic[OmniCosmos`Private`level$$], {
             1}, "\<\"Facile\"\>"], 
            
            SetterBox[Dynamic[OmniCosmos`Private`level$$], {
             3}, "\<\"Difficile\"\>"]}
          },
          BaselinePosition->{1, 1},
          GridBoxSpacings->{"Columns" -> {
              Offset[0.27999999999999997`], {
               Offset[0.]}, 
              Offset[0.27999999999999997`]}, "Rows" -> {
              Offset[0.2], {
               Offset[0.4]}, 
              Offset[0.2]}}],
         Deployed->True],
        SetterBar[
         Dynamic[OmniCosmos`Private`level$$], {
         1 -> "Facile", 3 -> "Difficile"}]]},
      {
       ButtonBox["\<\"Nuova domanda\"\>",
        Appearance->Automatic,
        ButtonFunction:>(
         OmniCosmos`Private`exercise$$ = 
          OmniCosmos`Private`getExercise[OmniCosmos`Private`level$$]; 
         OmniCosmos`Private`userAnswer$$ = ""; 
         OmniCosmos`Private`feedback$$ = ""; Null),
        Evaluator->Automatic,
        Method->"Preemptive"]},
      {
       DynamicBox[ToBoxes[
         Column[{
           Style[
            OmniCosmos`Private`exercise$$["question"], 14], 
           If[
            KeyExistsQ[OmniCosmos`Private`exercise$$, "data"], 
            Grid[
             Partition[
              Flatten[
               ReplaceAll[
                OmniCosmos`Private`exercise$$[
                "data"], (Pattern[OmniCosmos`Private`a, 
                   Blank[]] -> Pattern[OmniCosmos`Private`b, 
                   Blank[]]) :> {
                 OmniCosmos`Private`a, "=", OmniCosmos`Private`b}]], 3]], 
            Nothing]}], StandardForm],
        ImageSizeCache->{206.015625, {5.970703125, 10.623046875}}]},
      {
       InputFieldBox[Dynamic[OmniCosmos`Private`userAnswer$$], String]},
      {
       ButtonBox["\<\"Verifica\"\>",
        Appearance->Automatic,
        ButtonFunction:>
         Module[{OmniCosmos`Private`result$ = 
           OmniCosmos`Private`checkAnswer[
            OmniCosmos`Private`exercise$$, OmniCosmos`Private`userAnswer$$]}, 
          OmniCosmos`Private`feedback$$ = 
           Which[OmniCosmos`Private`result$ === True, 
             Increment[OmniCosmos`Private`score$$]; "\:2705 Corretto!", 
             OmniCosmos`Private`result$ === "perfect", 
             Increment[OmniCosmos`Private`score$$]; "\:2705 Perfetto!", 
             OmniCosmos`Private`result$ === "close", 
             "\:26a0\:fe0f Vicino! Controlla le unit\[AGrave].", True, 
             "\:274c Sbagliato \[RightArrow] " <> 
             OmniCosmos`Private`exercise$$["hint"]]; Null],
        Evaluator->Automatic,
        Method->"Preemptive"]},
      {
       DynamicBox[ToBoxes[
         Style[OmniCosmos`Private`feedback$$, 14], StandardForm],
        ImageSizeCache->{236.0859375, {3.36328125, 13.23046875}}]}
     },
     DefaultBaseStyle->"Column",
     GridBoxAlignment->{"Columns" -> {{Left}}},
     GridBoxItemSize->{"Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}],
    "Column"]],
  DynamicModuleValues:>{}]], "Output",
 CellChangeTimes->{
